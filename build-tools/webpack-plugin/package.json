{
  "name": "baseline-webpack-plugin",
  "version": "1.0.0",
  "description": "Webpack plugin for Baseline compatibility checking",
  "main": "dist/build-tools/webpack-plugin/src/index.js",
  "types": "dist/build-tools/webpack-plugin/src/index.d.ts",
  "exports": {
    ".": "./dist/build-tools/webpack-plugin/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p ./tsconfig.json",
    "watch": "tsc --watch -p ./tsconfig.json"
  },
  "keywords": [
    "webpack",
    "plugin",
    "baseline",
    "compatibility",
    "browser-support"
  ],
  "author": "Baseline Tooling Team",
  "license": "MIT",
  "peerDependencies": {
    "webpack": "^5.0.0"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.12",
    "minimatch": "^10.2.4",
    "typescript": "^4.9.4",
    "web-features": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/webpack": "^5.28.0",
    "typescript": "^4.9.4"
  }
}
