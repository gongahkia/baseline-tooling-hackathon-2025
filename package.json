{
  "name": "groundwork",
  "displayName": "GroundWork",
  "description": "VSCode extension that integrates Baseline web feature compatibility data into the developer workflow",
  "version": "1.0.0",
  "publisher": "baseline-tooling",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Linters",
    "Other",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "baseline",
    "web-features",
    "compatibility",
    "browser-support",
    "progressive-enhancement"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:css",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onCommand:groundwork.checkCompatibility",
    "onCommand:groundwork.showDashboard"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "groundwork.checkCompatibility",
        "title": "Check Baseline Compatibility",
        "category": "GroundWork"
      },
      {
        "command": "groundwork.showDashboard",
        "title": "Show Compatibility Dashboard",
        "category": "GroundWork"
      },
      {
        "command": "groundwork.refreshData",
        "title": "Refresh Baseline Data",
        "category": "GroundWork"
      },
      {
        "command": "groundwork.configureProject",
        "title": "Configure Project Settings",
        "category": "GroundWork"
      }
    ],
    "configuration": {
      "title": "GroundWork",
      "properties": {
        "groundwork.browserSupport": {
          "type": "array",
          "default": [
            "chrome 90",
            "firefox 88",
            "safari 14"
          ],
          "description": "Target browser support for compatibility checking"
        },
        "groundwork.warningLevel": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ],
          "default": "warning",
          "description": "Warning level for features not meeting baseline requirements"
        },
        "groundwork.autoCheck": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check compatibility as you type"
        },
        "groundwork.cacheDuration": {
          "type": "number",
          "default": 3600,
          "description": "Cache duration for baseline data in seconds"
        },
        "groundwork.excludePatterns": {
          "type": "array",
          "default": [
            "node_modules/**",
            "dist/**",
            "build/**",
            "**/*.min.js",
            "**/*.min.css"
          ],
          "description": "Glob patterns that GroundWork should skip while scanning files"
        },
        "groundwork.targetMode": {
          "type": "string",
          "enum": [
            "custom-browser-support",
            "baseline-widely",
            "baseline-year"
          ],
          "default": "custom-browser-support",
          "description": "Controls whether GroundWork evaluates explicit browser targets or Baseline milestones"
        },
        "groundwork.baselineYear": {
          "type": "number",
          "default": 2023,
          "description": "Baseline year used when target mode is baseline-year"
        },
        "groundwork.widelyAvailableOnDate": {
          "type": "string",
          "default": "",
          "description": "Historical date to use when target mode is baseline-widely"
        },
        "groundwork.includeDownstreamBrowsers": {
          "type": "boolean",
          "default": false,
          "description": "Include downstream Chromium and Gecko browsers when resolving Baseline targets"
        }
      }
    },
    "views": {
      "groundwork": [
        {
          "id": "groundworkFeatures",
          "name": "Features",
          "when": "groundwork.hasProject"
        },
        {
          "id": "groundworkWarnings",
          "name": "Warnings",
          "when": "groundwork.hasWarnings"
        }
      ],
      "groundworkDashboard": [
        {
          "id": "groundworkDashboard",
          "name": "Dashboard"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "groundwork",
          "title": "GroundWork",
          "icon": "resources/groundwork-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "groundworkDashboard",
          "title": "Compatibility Dashboard",
          "icon": "resources/dashboard-icon.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "groundwork.checkCompatibility",
          "when": "editorTextFocus",
          "group": "groundwork"
        }
      ],
      "commandPalette": [
        {
          "command": "groundwork.checkCompatibility"
        },
        {
          "command": "groundwork.showDashboard"
        },
        {
          "command": "groundwork.refreshData"
        },
        {
          "command": "groundwork.configureProject"
        }
      ]
    },
    "languages": [
      {
        "id": "html",
        "extensions": [
          ".html",
          ".htm"
        ]
      },
      {
        "id": "css",
        "extensions": [
          ".css"
        ]
      },
      {
        "id": "javascript",
        "extensions": [
          ".js",
          ".mjs"
        ]
      },
      {
        "id": "typescript",
        "extensions": [
          ".ts",
          ".tsx"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && npm run lint && node --test test/*.test.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "baseline-browser-mapping": "^2.10.12",
    "browserslist": "^4.21.5",
    "caniuse-lite": "^1.0.30001418",
    "minimatch": "^10.2.4",
    "node-cache": "^5.1.2",
    "web-features": "^3.22.0"
  }
}
